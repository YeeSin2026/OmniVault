# LLM API（必填，兼容任何 OpenAI 格式的服务商）
# 默认 DeepSeek，也支持通义千问/GLM/OpenAI 等
# 使用其他服务商时设 LLM_BASE_URL + LLM_MODEL
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 兼容旧配置名（如使用 DEEPSEEK_* 则不必重复设置 LLM_*）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 飞书 Bot（可选，默认空）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Whisper（tiny/base/small/medium/large-v3）
WHISPER_MODEL_SIZE=medium

# Webhook 通知（处理完成时发送）
# 类型: feishu / wechat（群机器人 webhook URL）
WEBHOOK_URL=
WEBHOOK_TYPE=

# 抖音登录（切换评论区功能，默认关闭）
DOUYIN_LOGIN_ENABLED=false

# 采集限制
MAX_VIDEOS_PER_DAY=200
MAX_COMMENTS_PER_VIDEO=50

# Obsidian Vault 集成（可选）
# 设置后，内容处理完成自动写入 .md 文件到该目录
# 目录结构: {vault}/{platform}/{YYYY-MM}/{content_id}.md
# OBSIDIAN_VAULT_PATH=/vault

# ── 激活码验证（默认开启）──
# 关闭后跳过激活：ACTIVATION_ENABLED=false
ACTIVATION_ENABLED=true
# ACTIVATION_SECRET 已内置于 Docker 镜像，无需在此配置

# ── 激活通知（可选）──
# 用户激活时通过 Telegram Bot 通知作者
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234
# TELEGRAM_CHAT_ID=123456789

# Docker 端口
PORT=8080
HOST=0.0.0.0

# ── 视觉抓取方案（可选，默认关闭）──
# 启用后，对反爬严格的页面使用截图+多模态VLM识别
# 要求：本地部署支持多模态的大模型（Gemma 4 / GPT-4V / UI-TARS 等）
# ⚠️ 可能触发平台风控，详见 VISION.md
VISION_ENABLED=false
# VISION_ENDPOINT=http://127.0.0.1:8000/v1/chat/completions
# VISION_MODEL=UI-TARS-1.5-7B-6bit
# VISION_API_KEY=

# 存储路径（Docker 下使用默认值 /data/*）
# KNOWLEDGE_DB_PATH=/data/knowledge.db
# JOBS_DB_PATH=/data/jobs.db
# TEMP_DIR=/tmp/omnivault
